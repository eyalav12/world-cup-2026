# Copy to .env.local for local development (.env.local is gitignored)

# Spring Boot API (server-side Next fetches & rewrites)
API_BASE_URL=http://localhost:8083

# FastAPI agents (server-side only)
AGENT_API_URL=http://localhost:8000

# Optional: browser-visible API base (usually not needed — app uses /api/backend proxy)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8083
