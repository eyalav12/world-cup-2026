# Copy to .env.docker and fill in your values.
# Usage: docker compose --env-file .env.docker up --build

# Existing Postgres on your machine (not a Docker postgres container)
DB_URL=jdbc:postgresql://host.docker.internal:2000/eyal
DB_USERNAME=eyal
DB_PASSWORD=your_db_password

RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

FOOTBALLDATA_API_TOKEN=your_football_data_api_token
ODDSDATA_API_TOKEN=your_odds_api_token
NEWSDATA_API_TOKEN=your_news_api_token

OPENAI_API_KEY=your_openai_api_key
